@page
@model ProductosWeb.Pages.Productos.EliminarModel
@{
}

<h1>Eliminar Producto</h1>

<div class="container">
    <form method="post">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Html.DisplayFor(modelo => modelo.producto.Nombre)</h5>
                    <p class="card-text">
                        <div>
                            <b>
                                @Html.DisplayNameFor(modelo => modelo.producto.Categoria)
                            </b>
                            @Html.DisplayFor(modelo => modelo.producto.Categoria)
                       
                            <b>@Html.DisplayNameFor(modelo => modelo.producto.SubCategoria)</b>
                            @Html.DisplayFor(modelo => modelo.producto.SubCategoria)
                        </div>
                        <div>
                            <b>@Html.DisplayNameFor(modelo => modelo.producto.Precio)</b>
                            @Html.DisplayFor(modelo => modelo.producto.Precio)
                        </div>
                        <div>
                            <b>@Html.DisplayNameFor(modelo => modelo.producto.PrecioUSD)</b>
                            @Html.DisplayFor(modelo => modelo.producto.PrecioUSD)
                        </div>
                        <div>
                            <b>@Html.DisplayNameFor(modelo => modelo.producto.Stock)</b>
                            @Html.DisplayFor(modelo => modelo.producto.Stock)
                        </div>
                        <div>
                            <b>@Html.DisplayNameFor(modelo => modelo.producto.CodigoBarras)</b>
                            @Html.DisplayFor(modelo => modelo.producto.CodigoBarras)
                        </div>
                    </p>
                    <p class="card-text"> <small class="text-muted"> @Html.DisplayFor(modelo => modelo.producto.Descripcion)</small> </p>

                </div>
            </div>
        </div>
        <a type="button" class="btn btn-info" asp-page="./Index">Regresar</a>
        <button type="submit" class="btn btn-danger">Eliminar</button>
    
    </form>
</div>

